---
import PageLayout from "../../layouts/PageLayout.astro";
import { getCollection, render } from "astro:content";
import Carrossel from "../../components/Carrossel.astro";

export async function getStaticPaths() {
  const noticias = await getCollection("noticias", ({ data }) => !data.draft);
  return noticias.map((noticia) => ({
    params: { slug: noticia.id },
    props: { noticia },
  }));
}

const { noticia } = Astro.props;
const { Content } = await render(noticia);

const { title, description, date, projeto, tags, fotos } = noticia.data;

const formatDate = (d: Date) =>
  d.toLocaleDateString("pt-BR", { day: "numeric", month: "long", year: "numeric" });
---

<PageLayout title={`${title} — Cataventus`} description={description}>
  <article class="container mx-auto px-6 py-16 max-w-3xl">

    <header class="mb-12">
      <!-- volta -->
      <a
        href="/noticias"
        class="inline-flex items-center gap-1.5 text-sm text-ash hover:text-ink transition-colors mb-8"
      >
        ← Todas as notícias
      </a>

      <!-- badges -->
      <div class="flex flex-wrap gap-2 mb-6">
        {projeto && (
          <a
            href={`/projetos/${projeto}`}
            class="text-xs font-semibold uppercase tracking-widest bg-brand-orange/10 text-brand-orange rounded-full px-3 py-1 hover:bg-brand-orange/20 transition-colors"
          >
            {projeto.replace(/-/g, " ")}
          </a>
        )}
        {tags.map((tag) => (
          <span class="text-xs font-medium bg-sheet text-ash rounded-full px-3 py-1">
            {tag}
          </span>
        ))}
      </div>

      <h1 class="font-display text-4xl md:text-5xl leading-tight mb-4">{title}</h1>
      <p class="text-ash text-lg leading-relaxed mb-6">{description}</p>

      <time
        datetime={date.toISOString()}
        class="text-sm text-ash tabular-nums"
      >
        {formatDate(date)}
      </time>
    </header>

    <!-- carrossel de fotos (quando existir) -->
    {fotos.length > 0 && <Carrossel fotos={fotos} />}

    <!-- conteúdo markdown -->
    <div
      class="prose prose-lg max-w-none
             prose-headings:font-display prose-headings:text-ink prose-headings:font-normal
             prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
             prose-p:text-ash prose-p:leading-relaxed
             prose-strong:text-ink prose-strong:font-semibold
             prose-a:text-brand-orange prose-a:no-underline hover:prose-a:underline
             prose-hr:border-rule
             prose-ul:text-ash prose-li:marker:text-brand-orange"
    >
      <Content />
    </div>

    <!-- rodapé: link para projeto relacionado -->
    {projeto && (
      <footer class="mt-16 pt-8 border-t border-rule">
        <p class="text-sm text-ash mb-3">Projeto relacionado</p>
        <a
          href={`/projetos/${projeto}`}
          class="inline-flex items-center gap-2 font-semibold text-brand-orange hover:gap-3 transition-all duration-200"
        >
          Ver projeto: {projeto.replace(/-/g, " ")} →
        </a>
      </footer>
    )}

  </article>
</PageLayout>
