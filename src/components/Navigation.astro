---
const links = [
  { href: "/quem-somos", label: "Quem Somos" },
  { href: "/projetos", label: "Projetos" },
  { href: "/noticias", label: "Notícias" },
  { href: "/contato", label: "Contato" },
]

const current = Astro.url.pathname
---

<nav id="nav-menu" class="hidden md:flex items-center gap-6" aria-label="Menu principal">
  <ul class="flex flex-col md:flex-row items-start md:items-center gap-1 md:gap-6">
    {links.map(({ href, label }) => {
      const active = current === href || current.startsWith(href + "/")
      return (
        <li>
          <a
            href={href}
            class:list={[
              "block px-2 py-1 text-sm font-medium rounded transition-colors",
              active
                ? "text-brand-orange"
                : "text-ink hover:text-brand-orange",
            ]}
            aria-current={active ? "page" : undefined}
          >
            {label}
          </a>
        </li>
      )
    })}
  </ul>
</nav>
