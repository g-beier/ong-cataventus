---
import Logo from "./Logo.astro";
import { footerColumns, siteInfo } from "../config/nav";

const year = new Date().getFullYear();
const columns = footerColumns;
---

<footer class="border-rule mt-20 border-t">
  <div class="container mx-auto px-6 py-12">
    <!-- grade principal -->
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <!-- logo + tagline -->
      <div class="flex flex-col gap-4">
        <a href="/" aria-label="Cataventus — página inicial">
          <Logo class="h-24 w-auto" />
        </a>
        <p class="text-ash max-w-[16rem] text-sm leading-relaxed">
          {siteInfo.tagline}
        </p>
      </div>

      <!-- colunas de links -->
      {
        columns.map(({ title, links }) => (
          <div class="flex flex-col gap-3">
            <p class="text-ash text-xs font-semibold tracking-widest uppercase">
              {title}
            </p>
            <ul class="flex flex-col gap-2">
              {links.map(({ label, href, rel, target }) => (
                <li>
                  <a
                    href={href}
                    rel={rel}
                    target={target}
                    class="text-ink hover:text-brand-orange text-sm transition-colors"
                  >
                    {label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <!-- rodapé inferior -->
    <div
      class="border-rule text-ash mt-10 flex flex-col items-center justify-between gap-2 border-t pt-6 text-xs sm:flex-row"
    >
      <span>&copy; {year} {siteInfo.name}. Todos os direitos reservados.</span>
      <span>CNPJ {siteInfo.cnpj}</span>
    </div>
  </div>
</footer>
