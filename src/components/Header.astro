---
import Logo from "./Logo.astro"
import Navigation from "./Navigation.astro"
import { navLinks } from "../config/nav"
---

<header class="sticky top-0 z-50 bg-canvas/90 backdrop-blur border-b border-rule">
  <div class="container mx-auto flex items-center justify-between px-6 py-3 gap-6">

    <a href="/" aria-label="Cataventus — página inicial">
      <Logo horizontal class="h-8 w-auto" />
    </a>

    <!-- desktop nav -->
    <Navigation />

    <!-- botão hamburguer (mobile) -->
    <button
      id="nav-toggle"
      class="md:hidden flex flex-col justify-center gap-1.5 w-8 h-8 p-1"
      aria-controls="nav-menu"
      aria-expanded="false"
      aria-label="Abrir menu"
    >
      <span class="block h-0.5 bg-current rounded transition-all duration-200 origin-center" id="bar1"></span>
      <span class="block h-0.5 bg-current rounded transition-all duration-200" id="bar2"></span>
      <span class="block h-0.5 bg-current rounded transition-all duration-200 origin-center" id="bar3"></span>
    </button>

  </div>

  <!-- mobile nav dropdown -->
  <div
    id="nav-mobile"
    class="hidden md:hidden border-t border-rule"
  >
    <div class="container mx-auto px-6 py-4">
      <ul class="flex flex-col gap-1">
        {navLinks.map(({ href, label }) => {
          const active = Astro.url.pathname === href || Astro.url.pathname.startsWith(href + "/")
          return (
            <li>
              <a
                href={href}
                class:list={[
                  "block px-2 py-2 text-sm font-medium rounded transition-colors",
                  active
                    ? "text-brand-orange"
                    : "text-ink hover:text-brand-orange",
                ]}
                aria-current={active ? "page" : undefined}
              >
                {label}
              </a>
            </li>
          )
        })}
      </ul>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById("nav-toggle")!
  const menu   = document.getElementById("nav-mobile")!
  const bar1   = document.getElementById("bar1")!
  const bar2   = document.getElementById("bar2")!
  const bar3   = document.getElementById("bar3")!

  toggle.addEventListener("click", () => {
    const open = toggle.getAttribute("aria-expanded") === "true"
    toggle.setAttribute("aria-expanded", String(!open))
    menu.classList.toggle("hidden", open)

    // animação X
    bar1.style.transform = open ? "" : "translateY(8px) rotate(45deg)"
    bar2.style.opacity   = open ? "" : "0"
    bar3.style.transform = open ? "" : "translateY(-8px) rotate(-45deg)"
  })
</script>
