---
interface Props {
  id: string;
  title: string;
  description: string;
  objective: string;
  targetAudience: string[];
  status: string;
}

const { id, title, description, objective, targetAudience, status } = Astro.props;
---

<div
  class="proj-panel col-span-full overflow-hidden"
  data-panel-id={id}
  style="max-height: 0; transition: max-height 450ms ease-in-out;"
  hidden
>
  <div class="rounded-2xl border border-rule bg-canvas mt-4 p-6 md:p-8">

    <!-- fechar -->
    <div class="flex justify-end mb-4">
      <button
        class="pp-close size-8 rounded-full flex items-center justify-center
               text-ash hover:text-ink hover:bg-sheet transition-colors"
        aria-label="Fechar"
      >
        ✕
      </button>
    </div>

    <!-- grid 2 colunas em md+ -->
    <div class="grid md:grid-cols-[1fr_1.2fr] gap-6 md:gap-10">

      <!-- col esquerda: badges + título + link -->
      <div class="flex flex-col justify-between gap-6">
        <div>
          <div class="flex flex-wrap gap-2 mb-3">
            <span class="text-xs font-semibold uppercase tracking-widest bg-brand-orange/10 text-brand-orange rounded-full px-3 py-1">
              {status}
            </span>
            {targetAudience.map((a) => (
              <span class="text-xs bg-sheet text-ash rounded-full px-3 py-1">{a}</span>
            ))}
          </div>
          <h3 class="font-display text-2xl md:text-3xl leading-tight">{title}</h3>
        </div>

        <a
          href={`/projetos/${id}`}
          class="inline-flex items-center gap-2 text-sm font-semibold text-brand-orange
                 hover:gap-3 transition-all duration-200 self-start"
        >
          Ver projeto completo →
        </a>
      </div>

      <!-- col direita: descrição + objetivo -->
      <div class="flex flex-col gap-4 border-t md:border-t-0 md:border-l border-rule pt-6 md:pt-0 md:pl-10">
        <p class="text-ash leading-relaxed">{description}</p>
        <p class="text-sm text-ink leading-relaxed">
          <span class="font-semibold">Objetivo: </span>{objective}
        </p>
      </div>

    </div>
  </div>
</div>
